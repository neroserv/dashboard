APP_NAME=neroserv
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Mollie (Laravel Cashier Mollie) – Checkout, Billing, Abos
# API Key aus https://www.mollie.com/dashboard/developers/api-keys
MOLLIE_KEY=test_...
# Optional: Öffentliche Webhook-URL für lokale Entwicklung (z. B. ngrok).
# Wenn nicht gesetzt und APP_URL ist localhost/.test: Webhook wird weggelassen (Zahlung funktioniert trotzdem).
# MOLLIE_WEBHOOK_URL=https://xyz.ngrok.io/webhooks/mollie

# Optional: Cashier / Billing
# CASHIER_CURRENCY=eur
# CASHIER_CURRENCY_LOCALE=de_DE
# CASHIER_WEBHOOK_URL=webhooks/mollie
# BILLING_GRACE_PERIOD_DAYS=7
# AI_TOKENS_PRICE_500=5
# AI_TOKENS_PRICE_2000=15
# AI_TOKENS_PRICE_10000=50

# Skrime Domain Reseller API
SKRIME_API_URL=https://skrime.eu/api
SKRIME_API_TOKEN=
# SKRIME_API_TIMEOUT=30
# SKRIME_MARGIN_TYPE=fixed
# SKRIME_MARGIN_VALUE=2
