APP_NAME=neroserv
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Daily support PIN secret (user_id + secret + date). Set to a random string; used only server-side.
# SUPPORT_PIN_SECRET=

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Web Push (VAPID) – php artisan webpush:vapid
# VAPID_SUBJECT=https://example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Mollie (Laravel Cashier Mollie) – Checkout, Billing, Abos
# API Key aus https://www.mollie.com/dashboard/developers/api-keys
MOLLIE_KEY=test_...
# Optional: Öffentliche Webhook-URL für lokale Entwicklung (z. B. ngrok).
# Wenn nicht gesetzt und APP_URL ist localhost/.test: Webhook wird weggelassen (Zahlung funktioniert trotzdem).
# MOLLIE_WEBHOOK_URL=https://xyz.ngrok.io/webhooks/mollie

# Optional: Cashier / Billing
# CASHIER_CURRENCY=eur
# CASHIER_CURRENCY_LOCALE=de_DE
# CASHIER_WEBHOOK_URL=webhooks/mollie
# BILLING_GRACE_PERIOD_DAYS=7
# FALLBACK_MONTHLY_PRICE_TEAMSPEAK=0
# AI_TOKENS_PRICE_500=5
# AI_TOKENS_PRICE_2000=15
# AI_TOKENS_PRICE_10000=50
# OpenAI API-Schlüssel: pro Marke unter Admin → Erweiterungen (ChatGPT). Optional: OPENAI_ORGANIZATION / OPENAI_PROJECT in config/openai.php

# Skrime Domain Reseller API
SKRIME_API_URL=https://skrime.eu/api
SKRIME_API_TOKEN=
# SKRIME_API_TIMEOUT=30
# SKRIME_MARGIN_TYPE=fixed
# SKRIME_MARGIN_VALUE=2

BILLING_TOS_URL=https://neroserv.de/terms-of-service
BILLING_PRIVACY_URL=https://neroserv.de/privacy-policy

# Cloudflare DNS: Zone, Token und Domain werden pro Marke unter Admin → Erweiterungen (Cloudflare) gepflegt.
# Die folgenden Variablen werden von der App dafür nicht mehr gelesen.
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_DOMAIN=

# phpMyAdmin Signon (optional) – muss vom phpMyAdmin-Server aus erreichbar sein
# PHPMYADMIN_URL=https://pma.example.com
# PHPMYADMIN_SIGNON_URL=https://pma.example.com/signon.php
# Basis-URL für die Credentials-API; muss vom phpMyAdmin-Server aus erreichbar sein (z. B. öffentliche App-URL)
# PHPMYADMIN_CREDENTIALS_BASE_URL=https://gaming.praxishosting.de

# Discord OAuth (Login/Connect) + Bot (DM, Rolle, Slash-Command)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# Optional fallback in config; actual OAuth redirect_uri is built from the current request host (multi-domain).
# Register every customer URL in Discord → OAuth2 → Redirects, e.g. https://dash.neroserv.de/auth/discord/callback
# DISCORD_REDIRECT_URI=${APP_URL}/auth/discord/callback
# Guild, Kunden-Rolle und Invite-URL: pro Marke unter Admin → Erweiterungen (Discord).
# DISCORD_INVITE_URL= (unbenutzt – im Panel pflegen)
# Bot (DM, Slash-Commands) – weiter global:
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID= (unbenutzt – im Panel pflegen)
# DISCORD_CUSTOMER_ROLE_ID= (unbenutzt – im Panel pflegen)
# Discord Application Public Key (für Interaktionen-Signatur, z. B. /link)
# DISCORD_APPLICATION_PUBLIC_KEY=